 % =========================================================
% TEMPLATE RÉUTILISABLE (à placer dans le préambule)
% =========================================================
% Ce template trace les 6 sommets, les 7 segments et les lettres.
% Paramètre optionnel : r (le rayon des cercles, par défaut 1.5).
% La longueur de chaque arête sera garantie d'être exactement 2*r.
\newcommand{\templateNuage}[1][1.5]{
    % Enregistrement du rayon r
    \pgfmathsetmacro{\R}{#1}
    % Calcul de la hauteur des triangles équilatéraux de côté 2r
    \pgfmathsetmacro{\h}{\R*sqrt(3)}
    
    % Définition des coordonnées mathématiquement exactes
    \coordinate (C) at (-\R, 0);
    \coordinate (D) at (\R, 0);
    \coordinate (A) at (-\R-\h, \R);
    \coordinate (B) at (-\R-\h, -\R);
    \coordinate (E) at (\R+\h, \R);
    \coordinate (F) at (\R+\h, -\R);

    % Tracé des 7 segments (tous mesurent exactement 2r)
    \draw[thick] (A) -- (B) -- (C) -- cycle; % Triangle gauche
    \draw[thick] (D) -- (E) -- (F) -- cycle; % Triangle droit
    \draw[thick] (C) -- (D);                 % Segment central

    % Tracé des sommets et de leurs étiquettes (dégagées vers l'extérieur)
    \fill (A) circle (1.5pt) node[left=4pt] {A};
    \fill (B) circle (1.5pt) node[left=4pt] {B};
    
    % \fill (C) circle (1.5pt) node[above=4pt] {C};
    % \fill (D) circle (1.5pt) node[above=4pt] {D};
    % ---- LIGNES MODIFIÉES ----
    % C et D sont décalés vers l'intérieur de leurs triangles respectifs
    % pour laisser un espace net autour des 4 points de tangence rouges.
    \fill (C) circle (1.5pt) node[left=6pt] {C};
    \fill (D) circle (1.5pt) node[right=6pt] {D};
    % --------------------------
    
    \fill (E) circle (1.5pt) node[right=4pt] {E};
    \fill (F) circle (1.5pt) node[right=4pt] {F};
}
